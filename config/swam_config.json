{
  "_notes": [
    "SWAM instruments require initialization stimulus to activate physical modeling",
    "Send CC11 (expression) movement at track start to 'wake up' the instrument",
    "Without initial stimulus, SWAM may not produce sound on first notes"
  ],
  "instruments": {
    "violin": {
      "name": "SWAM Violin",
      "midi_channel": 0,
      "cc_mappings": {
        "expression": {
          "cc": 11,
          "description": "Overall expression/dynamics",
          "range": [0, 127],
          "default": 80,
          "curve": {
            "shape": 0.04,
            "symmetry": 0.8
          },
          "notes": "Exponential curve for natural dynamics"
        },
        "vibrato_depth": {
          "cc": 1,
          "description": "Vibrato depth",
          "range": [0, 110],
          "default": 0,
          "notes": "0 = no vibrato, 55 = moderate, 110 = intense (capped at 110)"
        },
        "vibrato_rate": {
          "cc": 17,
          "description": "Vibrato rate/speed",
          "range": [0, 127],
          "default": 64,
          "notes": "Controls vibrato speed independently from depth"
        },
        "tremolo": {
          "cc": 60,
          "description": "Bow tremolo speed (continuous)",
          "range": [0, 127],
          "default": 0,
          "values": {
            "off": 0,
            "slow": 50,
            "medium": 80,
            "fast": 127
          },
          "notes": "Continuous tremolo control: 0=off, higher values=faster tremolo. Variable speed for expressive control."
        },
        "portamento_time": {
          "cc": 5,
          "description": "Slide time between notes",
          "range": [1, 127],
          "default": 1,
          "notes": "Minimum value is 1, not 0"
        },
        "bow_force": {
          "cc": 20,
          "description": "Bow pressure/force",
          "range": [0, 127],
          "default": 64,
          "notes": "Controls bow pressure on strings"
        },
        "bow_position": {
          "cc": 21,
          "description": "Bow position on string",
          "range": [0, 127],
          "default": 64,
          "notes": "0 = sul tasto (fingerboard), 64 = normal, 127 = sul ponticello (bridge)"
        },
        "main_volume": {
          "cc": 7,
          "description": "Main volume",
          "range": [0, 127],
          "default": 100
        },
        "pan": {
          "cc": 10,
          "description": "Pan position",
          "range": [0, 127],
          "default": 64,
          "notes": "0 = hard left, 64 = center, 127 = hard right"
        },
        "reverb": {
          "cc": 90,
          "description": "Reverb send level",
          "range": [0, 127],
          "default": 40
        },
        "attack_ramp_time": {
          "cc": 80,
          "description": "Attack ramp time",
          "range": [0, 127],
          "default": 64,
          "notes": "Controls the smoothness of note onset"
        },
        "sustain": {
          "cc": 64,
          "description": "Legato/sustain pedal",
          "range": [0, 127],
          "values": {
            "off": 0,
            "on": 127
          },
          "curve": {
            "shape": 0.99
          },
          "notes": "Use for legato passages"
        },
        "harmonics": {
          "cc": 74,
          "description": "Harmonics (brightness/brilliance)",
          "range": [0, 127],
          "default": 64,
          "notes": "Custom mapping - adds harmonic content for brilliant tone"
        }
      },
      "envelopes": {
        "_notes": [
          "CC11 envelopes prevent flat/dead sound - EVERY note should have dynamic shaping",
          "Envelope points are (time_ratio, cc11_ratio) where ratios are 0.0-1.0",
          "time_ratio: 0.0=note start, 1.0=note end",
          "cc11_ratio: relative to base expression (1.0=base, 1.2=20% above base)"
        ],
        "default": {
          "type": "default",
          "description": "Standard envelope for most notes - natural attack and release",
          "notes": "Use for unmarked notes, quarter notes, half notes",
          "enabled_by_default": true,
          "points": [
            [0.0, 0.7],
            [0.15, 1.0],
            [0.7, 1.0],
            [1.0, 0.85]
          ]
        },
        "expressive": {
          "type": "expressive",
          "description": "Dynamic envelope with swell for expressive passages",
          "notes": "Use for slow melodies, cantabile phrases, emotional moments",
          "points": [
            [0.0, 0.6],
            [0.2, 1.1],
            [0.5, 1.05],
            [0.8, 1.0],
            [1.0, 0.8]
          ]
        },
        "gentle": {
          "type": "gentle",
          "description": "Soft, delicate envelope for quiet passages",
          "notes": "Use for pp/ppp, delicate phrases, sul tasto",
          "points": [
            [0.0, 0.75],
            [0.25, 0.95],
            [0.8, 0.9],
            [1.0, 0.7]
          ]
        },
        "percussive": {
          "type": "percussive",
          "description": "Sharp attack with fast decay for articulated notes",
          "notes": "Use for spiccato, détaché, rhythmic passages",
          "points": [
            [0.0, 0.8],
            [0.08, 1.15],
            [0.2, 0.85],
            [0.6, 0.75],
            [1.0, 0.6]
          ]
        }
      },
      "metrical_emphasis": {
        "_notes": [
          "Automatic emphasis on strong beats from MusicXML time signature",
          "Uses beatStrength property: 1.0 = downbeat, 0.5 = medium, 0.25 = weak",
          "emphasis_amount adds CC11 expression scaled by beat strength",
          "Example: 5 units means downbeats get +5 CC11, medium beats +2.5, weak beats +1.25"
        ],
        "enabled": true,
        "emphasis_amount": 5,
        "description": "Natural metrical accents on strong beats",
        "notes": "Set to 0 or disable for completely flat phrasing. Typical range: 3-8"
      },
      "portamento": {
        "_notes": [
          "Interval-aware portamento adds musical intelligence",
          "Small intervals = subtle slide, large leaps = expressive slide",
          "base_amount scales all portamento (0-127)"
        ],
        "enabled": true,
        "base_amount": 60,
        "interval_scaling": {
          "unison": 0.0,
          "half_step": 0.1,
          "whole_step": 0.2,
          "third": 0.35,
          "fourth_fifth": 0.5,
          "octave": 0.7,
          "large_leap": 0.9
        },
        "description": "Automatic portamento based on melodic intervals"
      },
      "articulations": {
        "_notes": [
          "IMPORTANT: Disable SWAM's internal auto-vibrato when using vibrato_mark or default_vibrato",
          "Both active simultaneously will fight each other and create pitch artifacts"
        ],
        "crescendo": {
          "cc": 11,
          "ramp_type": "exponential",
          "steps": 15,
          "description": "Gradual increase in volume",
          "notes": "Exponential ramp sounds more natural than linear"
        },
        "diminuendo": {
          "cc": 11,
          "ramp_type": "exponential",
          "steps": 15,
          "description": "Gradual decrease in volume"
        },
        "staccato": {
          "note_duration_percent": 35,
          "note_off_velocity": 110,
          "cc11_spike": 115,
          "cc11_sustain_percent": 40,
          "attack_ticks": 2,
          "decay_ticks": 4,
          "description": "Short, detached notes with smooth attack and rhythmic flow",
          "notes": "High note-off velocity (110) creates sharp bow stop. Smooth ramp to CC11 spike, gradual decay to 40% sustain for human-like bow articulation"
        },
        "legato": {
          "cc64": 127,
          "cc68": 127,
          "note_overlap": true,
          "overlap_percent": 10,
          "note_off_velocity": 30,
          "description": "Smooth, connected notes",
          "notes": "Low note-off velocity (30) for smooth bow lift. CC64=sustain, CC68=legato switch (if supported)"
        },
        "slur": {
          "cc5_portamento": 40,
          "cc64": 127,
          "note_overlap": true,
          "overlap_percent": 15,
          "note_off_velocity": 20,
          "description": "Legato with slide between notes",
          "notes": "Very low note-off velocity (20) for seamless bow connection. Higher overlap and portamento for smooth glide"
        },
        "vibrato_mark": {
          "cc1_target": 65,
          "cc17_target": 67,
          "delay_ms": 200,
          "ramp_duration_ms": 150,
          "pitch_dependent": {
            "enabled": true,
            "low_notes": {
              "threshold": "D4",
              "cc1_depth": 70,
              "cc17_rate": 60,
              "description": "Wider, slower vibrato on G/D strings"
            },
            "high_notes": {
              "threshold": "D5",
              "cc1_depth": 55,
              "cc17_rate": 75,
              "description": "Narrower, faster vibrato on A/E strings"
            },
            "mid_notes": {
              "cc1_depth": 65,
              "cc17_rate": 67,
              "description": "Balanced vibrato for middle register"
            }
          },
          "jitter": {
            "enabled": true,
            "cc1_range": 5,
            "cc17_range": 3,
            "interval_ms": 50,
            "description": "Add human-like variation during sustain"
          },
          "min_duration_seconds": 0.5,
          "description": "Natural vibrato with pitch-dependent depth/rate and continuous jitter",
          "notes": "CC1=depth (30-55), CC17=rate (60-75). Short notes skip vibrato. Jitter breaks synthetic pattern."
        },
        "default_vibrato": {
          "enabled": true,
          "cc1_target": 25,
          "cc17_target": 65,
          "delay_ms": 250,
          "ramp_duration_ms": 200,
          "min_duration_quarters": 1.0,
          "pitch_dependent": {
            "enabled": true,
            "low_notes": {
              "threshold": "D4",
              "cc1_depth": 28,
              "cc17_rate": 62,
              "description": "Subtle baseline vibrato on low strings"
            },
            "high_notes": {
              "threshold": "D5",
              "cc1_depth": 22,
              "cc17_rate": 68,
              "description": "Lighter baseline vibrato on high strings"
            },
            "mid_notes": {
              "cc1_depth": 25,
              "cc17_rate": 65,
              "description": "Balanced baseline for middle register"
            }
          },
          "jitter": {
            "enabled": true,
            "cc1_range": 3,
            "cc17_range": 2,
            "interval_ms": 60,
            "description": "Subtle variation for baseline vibrato"
          },
          "exclude_articulations": ["staccato", "staccatissimo", "spiccato"],
          "description": "Baseline vibrato for all sustained notes (~20-30% intensity)",
          "notes": "Real violinists use vibrato as fundamental tone production. Applies to quarter notes+ unless excluded. Lower intensity than explicit vibrato marks."
        },
        "accent": {
          "cc11_peak": 110,
          "cc74_harmonics": 20,
          "attack_ramp_ticks": 6,
          "decay_ramp_ticks": 4,
          "velocity_boost": 20,
          "note_off_velocity": 80,
          "description": "Emphasized note attack with gradual ramp for natural expression"
        },
        "marcato": {
          "cc11_peak": 120,
          "cc74_harmonics": 25,
          "attack_ramp_ticks": 8,
          "decay_ramp_ticks": 7,
          "velocity_boost": 25,
          "note_off_velocity": 90,
          "description": "Very strong accent with smooth ramp to heavy attack"
        },
        "sul_ponticello": {
          "cc21_value": 115,
          "cc21_range": [110, 127],
          "description": "Bow position near bridge (bright, metallic)",
          "notes": "CC21 controls bow position; higher = closer to bridge"
        },
        "sul_tasto": {
          "cc21_value": 15,
          "cc21_range": [0, 20],
          "description": "Bow position over fingerboard (soft, dark)",
          "notes": "CC21 controls bow position; lower = over fingerboard"
        },
        "spiccato": {
          "note_duration_percent": 40,
          "cc74_harmonics": 80,
          "description": "Bouncing bow stroke with added harmonics"
        },
        "glissando": {
          "cc5_portamento": 110,
          "cc64": 127,
          "note_overlap": true,
          "overlap_percent": 50,
          "description": "Continuous pitch slide between notes",
          "notes": "Very high portamento (110) + 50% overlap for dramatic glide effect"
        }
      },
      "dynamics": {
        "ppp": 20,
        "pp": 35,
        "p": 50,
        "mp": 65,
        "mf": 80,
        "f": 95,
        "ff": 110,
        "fff": 127
      }
    },
    "saxophone": {
      "name": "SWAM Saxophone",
      "midi_channel": 0,
      "cc_mappings": {
        "expression": {
          "cc": 11,
          "description": "Overall expression/dynamics",
          "range": [20, 127],
          "default": 80
        },
        "breath": {
          "cc": 2,
          "description": "Breath pressure",
          "range": [0, 127],
          "default": 64,
          "notes": "Essential for saxophone - controls air flow and tone"
        },
        "modulation": {
          "cc": 1,
          "description": "Vibrato depth",
          "range": [0, 127],
          "default": 0
        },
        "brightness": {
          "cc": 74,
          "description": "Tone brightness",
          "range": [0, 127],
          "default": 64
        },
        "sustain": {
          "cc": 64,
          "description": "Legato/sustain",
          "range": [0, 127],
          "default": 0
        },
        "growl": {
          "cc": 18,
          "description": "Growl amount (jazz effect)",
          "range": [0, 127],
          "default": 0,
          "notes": "Increases harmonic distortion for jazz styles"
        }
      },
      "articulations": {
        "crescendo": {
          "cc": 11,
          "ramp_type": "exponential",
          "steps": 15,
          "description": "Gradual increase in volume"
        },
        "diminuendo": {
          "cc": 11,
          "ramp_type": "exponential",
          "steps": 15,
          "description": "Gradual decrease in volume"
        },
        "staccato": {
          "note_duration_percent": 55,
          "cc2_spike": 100,
          "cc11_spike": 100,
          "description": "Short, tongued notes",
          "notes": "Breath spike for attack; slightly longer than violin staccato"
        },
        "legato": {
          "cc64": 127,
          "note_overlap": true,
          "overlap_percent": 10,
          "cc2_constant": 80,
          "description": "Smooth air flow between notes"
        },
        "slur": {
          "cc5_portamento": 30,
          "cc64": 127,
          "note_overlap": true,
          "overlap_percent": 15,
          "cc2_constant": 85,
          "description": "Legato with pitch bend between notes"
        },
        "vibrato_mark": {
          "cc1_target": 64,
          "delay_ms": 500,
          "ramp_duration_ms": 300,
          "description": "Gradually add vibrato after note onset"
        },
        "accent": {
          "cc2_peak": 110,
          "cc11_peak": 105,
          "description": "Tongued emphasis with breath"
        },
        "slap_tongue": {
          "velocity": 127,
          "cc2_spike": 127,
          "note_duration_percent": 20,
          "description": "Percussive slap effect"
        },
        "growl": {
          "cc18_value": 80,
          "cc18_range": [40, 100],
          "description": "Jazz growl effect",
          "notes": "CC18 adds harmonic distortion; use sparingly"
        },
        "glissando": {
          "cc5_portamento": 100,
          "cc64": 127,
          "note_overlap": true,
          "overlap_percent": 50,
          "cc2_constant": 85,
          "description": "Pitch slide with continuous air flow",
          "notes": "High portamento (100) + 50% overlap for clear glissando"
        }
      },
      "dynamics": {
        "ppp": 25,
        "pp": 40,
        "p": 55,
        "mp": 70,
        "mf": 85,
        "f": 100,
        "ff": 115,
        "fff": 127
      }
    }
  },
  "global_settings": {
    "ticks_per_beat": 480,
    "default_tempo": 120,
    "humanization": {
      "_notes": [
        "Humanization adds natural performance variations for realistic SWAM playback",
        "Use --humanize flag: none, subtle, default, aggressive"
      ],
      "subtle": {
        "timing_jitter_ms": 5.0,
        "velocity_variation_percent": 4.0,
        "duration_variation_percent": 1.5,
        "expression_flutter": 2,
        "bow_detach_variation_ms": 3.0,
        "description": "Light, conservative humanization for precise performances"
      },
      "default": {
        "timing_jitter_ms": 8.0,
        "velocity_variation_percent": 7.0,
        "duration_variation_percent": 2.0,
        "expression_flutter": 4,
        "bow_detach_variation_ms": 5.0,
        "description": "Natural humanization for realistic SWAM performances"
      },
      "aggressive": {
        "timing_jitter_ms": 12.0,
        "velocity_variation_percent": 10.0,
        "duration_variation_percent": 3.5,
        "expression_flutter": 6,
        "bow_detach_variation_ms": 8.0,
        "description": "Obvious variation for expressive, 'human-like' imperfection"
      }
    },
    "cc_interpolation": true,
    "notes": "CC interpolation smooths transitions between CC values"
  }
}
